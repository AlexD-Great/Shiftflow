# Database
DATABASE_URL="postgresql://user:password@localhost:5432/shiftflow"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# SideShift API (REQUIRED for swap functionality)
# Get your API key from: https://sideshift.ai/api
SIDESHIFT_SECRET="your-sideshift-api-secret-here"
SIDESHIFT_AFFILIATE_ID="your-affiliate-id-here" # Optional

# Cron Job Secret (for workflow monitoring)
CRON_SECRET="your-cron-secret-here"

# Admin access (comma-separated wallet addresses allowed to view /admin)
# Leave empty to allow any signed-in user
NEXT_PUBLIC_ADMIN_WALLETS=""

# CoinGecko API key (optional - increases rate limits on free tier)
# COINGECKO_API_KEY="your-coingecko-api-key"

# Email Service (optional - for workflow execution notifications)
# RESEND_API_KEY="your-resend-api-key"
